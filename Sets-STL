#include <iostream>
#include <set>
#include <algorithm>

using namespace std;

int main() {
    int q, type, x;
    cin >> q;
    
    set<int> s;
    
    while (q--) {
        cin >> type >> x;
        
        if (type == 1) {
            // Add element x to the set
            s.insert(x);
        } 
        else if (type == 2) {
            // Delete element x (does nothing if x isn't there)
            s.erase(x);
        } 
        else if (type == 3) {
            // Check if x exists
            if (s.find(x) != s.end()) {
                cout << "Yes" << endl;
            } else {
                cout << "No" << endl;
            }
        }
    }
    
    return 0;
}


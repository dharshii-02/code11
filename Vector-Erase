#include <vector>
#include <iostream>
#include <algorithm>

using namespace std;

int main() {
    int n, x, a, b, temp;
    cin >> n;
    
    vector<int> v;
    for(int i = 0; i < n; i++) {
        cin >> temp;
        v.push_back(temp);
    }
    
    // First query: Erase element at a specific 1-based position
    cin >> x;
    if (x <= v.size()) {
        v.erase(v.begin() + (x - 1));
    }
    
    // Second query: Erase range [a, b) where a and b are 1-based
    cin >> a >> b;
    // v.begin() + (a-1) points to the start of the range
    // v.begin() + (b-1) points to the end (exclusive)
    v.erase(v.begin() + (a - 1), v.begin() + (b - 1));
    
    // Output final size
    cout << v.size() << endl;
    
    // Output remaining elements
    for(int i = 0; i < v.size(); i++) {
        cout << v[i] << (i == v.size() - 1 ? "" : " ");
    }
    
    return 0;
}
